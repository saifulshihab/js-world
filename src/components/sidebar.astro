---
import type { CollectionEntry } from "astro:content";
import { topicCategories } from "../lib/topic-categories";

interface Props {
  topics: CollectionEntry<"topics">[];
}

const { topics } = Astro.props;

const byId = new Map(topics.map((topic) => [topic.id, topic]));
const currentPath = Astro.url.pathname.replace(/\/+$/, "");
---

<nav
  id="sidebar"
  class="fixed inset-y-0 left-0 z-40 flex h-screen w-72 -translate-x-full flex-col border-r border-[#2d333b] bg-[#1c1f24] transition-transform duration-200 ease-in-out lg:sticky lg:top-0 lg:z-auto lg:w-72 lg:shrink-0 lg:translate-x-0"
>
  <a href="/" class="block shrink-0 border-b border-[#2d333b] px-5 pt-6 pb-5">
    <span
      class="flex items-center gap-1.5 font-mono text-xl font-semibold tracking-tight text-[#e1e4e8]"
    >
      <span class="text-[#F0DB4F]">{"{"}</span>
      <span>JS World</span>
      <span class="text-[#F0DB4F]">{"}"}</span>
    </span>
    <span class="mt-1 block font-mono text-[11px] tracking-wide text-[#6a737d]"
      >{"// javascript, explained properly"}</span
    >
  </a>

  <div class="sidebar-scroll flex-1 space-y-7 overflow-y-auto px-5 py-6">
    {
      topicCategories.map((category) => (
        <div>
          <p class="mb-2.5 font-mono text-[11px] font-medium tracking-wider text-[#6a737d] select-none">
            {"// "}
            {category.name}
          </p>
          <ul class="space-y-1">
            {category.topics.map((id) => {
              const topic = byId.get(id);
              if (!topic) return null;
              const href = `/topics/${topic.id}`;
              const isActive = currentPath === href;
              return (
                <li>
                  <a
                    href={href}
                    aria-current={isActive ? "page" : undefined}
                    class:list={[
                      "block rounded-md border-l-2 py-1.5 pr-3 pl-3 text-[13px] leading-snug transition-colors duration-100",
                      isActive
                        ? "border-[#F0DB4F] bg-[#F0DB4F]/10 font-medium text-[#f3f5f7]"
                        : "border-transparent text-[#a4acb4] hover:border-[#3a4046] hover:bg-white/5 hover:text-[#f3f5f7]"
                    ]}
                  >
                    {topic.data.title}
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      ))
    }
  </div>

  <a
    href="https://github.com/saifulshihab/js-world"
    target="_blank"
    rel="noopener noreferrer"
    class="flex shrink-0 items-center gap-2 border-t border-[#2d333b] px-5 py-4 text-[13px] text-[#a4acb4] transition-colors duration-100 hover:bg-white/5 hover:text-[#f3f5f7]"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.57.1.78-.25.78-.55 0-.27-.01-1.16-.02-2.11-3.2.7-3.88-1.36-3.88-1.36-.52-1.33-1.28-1.69-1.28-1.69-1.04-.71.08-.7.08-.7 1.16.08 1.76 1.19 1.76 1.19 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.25.73-1.54-2.56-.29-5.25-1.28-5.25-5.7 0-1.26.45-2.29 1.19-3.09-.12-.29-.52-1.47.11-3.06 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.79 0c2.21-1.49 3.18-1.18 3.18-1.18.63 1.59.23 2.77.11 3.06.74.8 1.19 1.83 1.19 3.09 0 4.43-2.69 5.41-5.26 5.69.41.36.78 1.07.78 2.15 0 1.55-.01 2.8-.01 3.18 0 .3.21.66.79.55A10.52 10.52 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"></path>
    </svg>
    <span>View on GitHub</span>
  </a>
</nav>

<style>
  .sidebar-scroll {
    scrollbar-width: thin;
    scrollbar-color: #3a4046 transparent;
  }
  .sidebar-scroll::-webkit-scrollbar {
    width: 8px;
  }
  .sidebar-scroll::-webkit-scrollbar-thumb {
    background-color: #3a4046;
    border-radius: 9999px;
  }
  .sidebar-scroll::-webkit-scrollbar-track {
    background: transparent;
  }
</style>
