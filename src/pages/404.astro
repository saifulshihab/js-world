---
import BaseLayout from "../layouts/base-layout.astro";

const requestedPath = Astro.url.pathname;
---

<BaseLayout
  pageTitle="404 — Page not found | JS World"
  description="The page you're looking for doesn't exist. Browse JS World's full JavaScript topic index instead."
>
  <div class="flex min-h-screen items-center justify-center bg-[#fbfbfa] px-5 py-16 sm:px-8">
    <div class="max-w-lg text-center">
      <p class="mb-3 font-mono text-[13px] tracking-wider text-[#9a9488]">
        {"// 404"}
      </p>
      <h1 class="text-3xl font-semibold tracking-tight text-[#1c1f24]">
        This page doesn't exist. Yet?
      </h1>
      <p class="mt-3 text-[15px] leading-relaxed text-[#5b5850]">
        Somewhere between the request and the render, this one fell through.
      </p>

      <div
        class="mt-8 overflow-x-auto rounded-lg bg-[#24292e] p-5 text-left font-mono text-[13px] leading-relaxed whitespace-nowrap"
      >
        <p>
          <span class="text-[#F97583]">Uncaught</span>
          <span class="text-[#e1e4e8]">ReferenceError</span>:
          <span class="text-[#79B8FF]">page</span>
          <span class="text-[#6a737d]">is not defined</span>
        </p>
        <p class="text-[#6a737d]">
          &nbsp;&nbsp;&nbsp;&nbsp;at JSWorld.render (<span class="text-[#B392F0]">{requestedPath}</span>)
        </p>
      </div>

      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/"
          class="rounded-md bg-[#F0DB4F] px-5 py-2.5 text-[14px] font-medium text-[#1c1f24] transition-opacity hover:opacity-90"
        >
          Back to JS World →
        </a>
        <a
          href="/topics/scope"
          class="font-mono text-[13px] text-[#5b5850] hover:text-[#1c1f24] hover:underline"
        >
          or start with Scope
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
